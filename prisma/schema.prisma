// Annex Leather ERP — Prisma schema
// Phase 0 foundation tables only. Module-specific models (inventory,
// sales, accounts, etc.) are added as their modules are built.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum CurrencyCode {
  BDT
  INR
  USD
  EUR
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProductType {
  RAW_MATERIAL
  WORK_IN_PROGRESS
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
}

enum UnitOfMeasure {
  PCS
  KG
  G
  M
  M2
  L
  ML
  BOX
  PACK
  PAIR
  SET
}

enum WarehouseType {
  MAIN
  STORE
  WIP
  QUARANTINE
  DAMAGED
  SHOWROOM
}

enum InventoryDirection {
  IN
  OUT
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PaymentTerms {
  COD
  NET_15
  NET_30
  NET_45
  NET_60
  NET_90
}

enum PurchaseRequisitionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  CLOSED
}

enum PurchasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum GoodsReceivingStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseInvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PurchaseInvoiceMatch {
  UNMATCHED
  MATCHED
  DISPUTED
}

enum SupplierPaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  WIRE_TRANSFER
  MOBILE_BANKING
  OTHER
}

enum SupplierLedgerEntryType {
  PURCHASE
  PAYMENT
  ADJUSTMENT
  OPENING
}

enum ProductionOrderStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum ProductionStageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum AssetStatus {
  IN_USE
  IN_STORAGE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
}

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  NONE
}

enum AssetMovementType {
  REGISTRATION
  TRANSFER
  MAINTENANCE
  DEPRECIATION
  DISPOSAL
  REVALUATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  CHANGES_REQUESTED
  ESCALATED
}

enum ApprovalStepStatus {
  WAITING
  ACTIVE
  APPROVED
  REJECTED
  SKIPPED
  CHANGES_REQUESTED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerType {
  RETAIL
  WHOLESALE
  CORPORATE
  ONLINE
  EXPORT
}

enum CustomerLedgerEntryType {
  OPENING
  INVOICE
  PAYMENT
  RETURN
  ADJUSTMENT
}

enum CustomerInteractionType {
  CALL
  EMAIL
  MEETING
  NOTE
  COMPLAINT
  FOLLOW_UP
  OTHER
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum PosSaleStatus {
  COMPLETED
  VOIDED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PosPaymentMethod {
  CASH
  CARD
  MOBILE_BANKING
  BANK_TRANSFER
  CREDIT
  GIFT_CARD
  OTHER
}

enum PosReturnStatus {
  COMPLETED
  VOIDED
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & RBAC
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  name            String
  phone           String?
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  defaultBranchId String?
  defaultBranch   Branch?    @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id])

  roles         UserRole[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  notifications Notification[] @relation("NotificationRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id     String @id @default(cuid())
  /// "<module>:<action>" — see src/lib/permissions.ts
  key    String @unique
  module String
  action String

  roles RolePermission[]

  @@index([module])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Multi-branch
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id                 String       @id @default(cuid())
  code               String       @unique
  name               String
  type               String       @default("MAIN") // MAIN / FACTORY / SHOWROOM / WAREHOUSE
  currency           CurrencyCode @default(BDT)
  address            String?
  phone              String?
  email              String?
  allowNegativeStock Boolean      @default(false)
  isActive           Boolean      @default(true)

  defaultForUsers  User[]                @relation("UserDefaultBranch")
  periods          Period[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  warehouses       Warehouse[]
  ledger           InventoryLedger[]
  suppliers        Supplier[]
  requisitions     PurchaseRequisition[]
  purchaseOrders   PurchaseOrder[]
  grns             GoodsReceiving[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]
  supplierLedger   SupplierLedger[]
  productionOrders ProductionOrder[]
  assets           Asset[]
  assetMovements   AssetMovement[]
  customers        Customer[]
  customerLedger   CustomerLedger[]
  posSessions      PosSession[]
  posSales         PosSale[]
  posReturns       PosReturn[]
  wholesaleInvoices WholesaleInvoice[]
  wholesaleReturns  WholesaleReturn[]
  corporateQuotes     CorporateQuote[]
  corporateOrders     CorporateOrder[]
  corporateDeliveries CorporateDelivery[]
  corporateInvoices   CorporateInvoice[]
  chartAccounts       ChartAccount[]
  journalEntries      JournalEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// Fiscal period lock (used by accounts + inventory stock freeze)
// ─────────────────────────────────────────────────────────────────────────────

model Period {
  id       String       @id @default(cuid())
  branchId String
  branch   Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String // e.g. "FY2025-26 Apr"
  startsAt DateTime
  endsAt   DateTime
  status   PeriodStatus @default(OPEN)

  journalEntries JournalEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([branchId, status])
  @@index([startsAt, endsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit log (append-only; no update/delete in app code)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  actorId    String?
  actor      User?   @relation("AuditActor", fields: [actorId], references: [id])
  branchId   String?
  branch     Branch? @relation(fields: [branchId], references: [id])
  module     String
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([branchId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications (SSE-delivered in Phase 1)
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id          String               @id @default(cuid())
  recipientId String
  recipient   User                 @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?              @relation(fields: [branchId], references: [id])
  severity    NotificationSeverity @default(INFO)
  module      String
  title       String
  body        String?
  href        String?
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([module])
}

// ─────────────────────────────────────────────────────────────────────────────
// Product master
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("CategoryTree")
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model ProductBrand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String                    @id @default(cuid())
  sku                String                    @unique
  barcode            String?                   @unique
  name               String
  description        String?
  type               ProductType               @default(FINISHED_GOOD)
  unit               UnitOfMeasure             @default(PCS)
  categoryId         String?
  category           ProductCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId            String?
  brand              ProductBrand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  costPrice          Decimal                   @default(0) @db.Decimal(18, 4)
  sellPrice          Decimal                   @default(0) @db.Decimal(18, 4)
  taxRate            Decimal                   @default(0) @db.Decimal(5, 2)
  reorderLevel       Decimal                   @default(0) @db.Decimal(18, 4)
  reorderQty         Decimal                   @default(0) @db.Decimal(18, 4)
  isActive           Boolean                   @default(true)
  imageUrl           String?
  ledger             InventoryLedger[]
  requisitionItems   PurchaseRequisitionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  grnItems           GoodsReceivingItem[]
  invoiceItems       PurchaseInvoiceItem[]
  producedInOrders   ProductionOrder[]         @relation("ProductionOutputProduct")
  materialsOfOrders  ProductionMaterial[]
  outputsOfOrders    ProductionOutput[]
  posSaleItems       PosSaleItem[]
  posReturnItems     PosReturnItem[]
  wholesaleItems     WholesaleInvoiceItem[]
  wholesaleReturns   WholesaleReturnItem[]
  corpQuoteItems     CorporateQuoteItem[]
  corpOrderItems     CorporateOrderItem[]
  corpDeliveryItems  CorporateDeliveryItem[]
  corpInvoiceItems   CorporateInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────────────
// Warehouse + stock ledger (single source of truth for inventory)
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id       String            @id @default(cuid())
  branchId String
  branch   Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code     String
  name     String
  type     WarehouseType     @default(MAIN)
  address  String?
  isActive Boolean           @default(true)
  ledger   InventoryLedger[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  goodsReceivings GoodsReceiving[]

  productionMaterialSources ProductionMaterial[] @relation("ProductionMaterialFromWarehouse")
  productionOutputs         ProductionOutput[]   @relation("ProductionOutputToWarehouse")
  posSessions               PosSession[]
  posSales                  PosSale[]
  posReturns                PosReturn[]
  wholesaleInvoices         WholesaleInvoice[]
  wholesaleReturns          WholesaleReturn[]
  corporateOrders           CorporateOrder[]
  corporateDeliveries       CorporateDelivery[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
}

model InventoryLedger {
  id          String             @id @default(cuid())
  branchId    String
  branch      Branch             @relation(fields: [branchId], references: [id])
  warehouseId String
  warehouse   Warehouse          @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product            @relation(fields: [productId], references: [id])
  direction   InventoryDirection
  quantity    Decimal            @db.Decimal(18, 4)
  costPerUnit Decimal            @default(0) @db.Decimal(18, 4)
  refType     String
  refId       String?
  note        String?
  createdById String?

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([branchId, warehouseId, productId])
  @@index([refType, refId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Suppliers
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id             String         @id @default(cuid())
  branchId       String
  branch         Branch         @relation(fields: [branchId], references: [id])
  /// Human supplier code (e.g. SUP-001)
  code           String         @unique
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  taxId          String?
  paymentTerms   PaymentTerms   @default(NET_30)
  currency       CurrencyCode   @default(BDT)
  openingBalance Decimal        @default(0) @db.Decimal(18, 4)
  status         SupplierStatus @default(ACTIVE)
  notes          String?
  createdById    String?

  purchaseOrders   PurchaseOrder[]
  grns             GoodsReceiving[]
  purchaseInvoices PurchaseInvoice[]
  payments         SupplierPayment[]
  ledger           SupplierLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Requisition (PR)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseRequisition {
  id             String                    @id @default(cuid())
  branchId       String
  branch         Branch                    @relation(fields: [branchId], references: [id])
  /// Human PR number (e.g. PR-2026-001)
  number         String                    @unique
  department     String
  requestedBy    String
  priority       PurchasePriority          @default(MEDIUM)
  status         PurchaseRequisitionStatus @default(DRAFT)
  requiredDate   DateTime
  notes          String?
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?

  items          PurchaseRequisitionItem[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([createdAt])
}

model PurchaseRequisitionItem {
  id             String              @id @default(cuid())
  requisitionId  String
  requisition    PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Free-text name when no SKU exists yet
  productName    String
  unit           UnitOfMeasure       @default(PCS)
  quantity       Decimal             @db.Decimal(18, 4)
  estimatedPrice Decimal             @default(0) @db.Decimal(18, 4)
  note           String?

  @@index([requisitionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Order (PO)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String               @id @default(cuid())
  branchId      String
  branch        Branch               @relation(fields: [branchId], references: [id])
  /// Human PO number (e.g. PO-2026-001)
  number        String               @unique
  supplierId    String
  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  requisitionId String?
  requisition   PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  status        PurchaseOrderStatus  @default(DRAFT)
  orderDate     DateTime             @default(now())
  deliveryDate  DateTime
  currency      CurrencyCode         @default(BDT)
  subtotal      Decimal              @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 4)
  discountTotal Decimal              @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal              @default(0) @db.Decimal(18, 4)
  notes         String?
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?
  cancelledAt   DateTime?

  items    PurchaseOrderItem[]
  grns     GoodsReceiving[]
  invoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([supplierId])
  @@index([requisitionId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  description     String?
  unit            UnitOfMeasure @default(PCS)
  orderedQty      Decimal       @db.Decimal(18, 4)
  receivedQty     Decimal       @default(0) @db.Decimal(18, 4)
  unitPrice       Decimal       @db.Decimal(18, 4)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  discountRate    Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal       @default(0) @db.Decimal(18, 4)

  grnItems GoodsReceivingItem[]

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Goods Receiving Note (GRN)
// ─────────────────────────────────────────────────────────────────────────────

model GoodsReceiving {
  id              String               @id @default(cuid())
  branchId        String
  branch          Branch               @relation(fields: [branchId], references: [id])
  number          String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  warehouseId     String
  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  status          GoodsReceivingStatus @default(DRAFT)
  receivedDate    DateTime             @default(now())
  receivedById    String
  notes           String?
  invoiceId       String?

  items    GoodsReceivingItem[]
  invoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([purchaseOrderId])
  @@index([supplierId])
}

model GoodsReceivingItem {
  id                  String            @id @default(cuid())
  grnId               String
  grn                 GoodsReceiving    @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  receivedQty         Decimal           @db.Decimal(18, 4)
  rejectedQty         Decimal           @default(0) @db.Decimal(18, 4)
  unitCost            Decimal           @db.Decimal(18, 4)
  note                String?

  @@index([grnId])
  @@index([purchaseOrderItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Invoice (supplier bill, 3-way match with PO + GRN)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseInvoice {
  id              String                @id @default(cuid())
  branchId        String
  branch          Branch                @relation(fields: [branchId], references: [id])
  number          String                @unique
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  grnId           String?
  grn             GoodsReceiving?       @relation(fields: [grnId], references: [id], onDelete: SetNull)
  status          PurchaseInvoiceStatus @default(PENDING)
  matching        PurchaseInvoiceMatch  @default(UNMATCHED)
  invoiceDate     DateTime              @default(now())
  dueDate         DateTime
  currency        CurrencyCode          @default(BDT)
  subtotal        Decimal               @default(0) @db.Decimal(18, 4)
  taxTotal        Decimal               @default(0) @db.Decimal(18, 4)
  discountTotal   Decimal               @default(0) @db.Decimal(18, 4)
  grandTotal      Decimal               @default(0) @db.Decimal(18, 4)
  paidAmount      Decimal               @default(0) @db.Decimal(18, 4)
  notes           String?
  createdById     String?

  items    PurchaseInvoiceItem[]
  payments SupplierPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([supplierId])
  @@index([dueDate])
}

model PurchaseInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  description String?
  unit        UnitOfMeasure   @default(PCS)
  quantity    Decimal         @db.Decimal(18, 4)
  unitPrice   Decimal         @db.Decimal(18, 4)
  taxRate     Decimal         @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal         @db.Decimal(18, 4)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Supplier Payment
// ─────────────────────────────────────────────────────────────────────────────

model SupplierPayment {
  id          String                @id @default(cuid())
  branchId    String
  branch      Branch                @relation(fields: [branchId], references: [id])
  number      String                @unique
  supplierId  String
  supplier    Supplier              @relation(fields: [supplierId], references: [id])
  invoiceId   String?
  invoice     PurchaseInvoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  method      SupplierPaymentMethod @default(BANK_TRANSFER)
  paymentDate DateTime              @default(now())
  amount      Decimal               @db.Decimal(18, 4)
  currency    CurrencyCode          @default(BDT)
  reference   String?
  notes       String?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, createdAt])
  @@index([supplierId, createdAt])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Supplier Ledger (append-only; runs debit/credit per supplier)
// Debit = purchase (increases payable). Credit = payment (reduces payable).
// ─────────────────────────────────────────────────────────────────────────────

model SupplierLedger {
  id          String                  @id @default(cuid())
  branchId    String
  branch      Branch                  @relation(fields: [branchId], references: [id])
  supplierId  String
  supplier    Supplier                @relation(fields: [supplierId], references: [id])
  entryType   SupplierLedgerEntryType
  refType     String
  refId       String?
  description String
  debit       Decimal                 @default(0) @db.Decimal(18, 4)
  credit      Decimal                 @default(0) @db.Decimal(18, 4)
  entryDate   DateTime                @default(now())
  createdById String?

  createdAt DateTime @default(now())

  @@index([supplierId, createdAt])
  @@index([branchId, createdAt])
  @@index([refType, refId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Factory Management
// Production orders convert raw materials into finished goods. Material issue
// and finished-goods receipt both post InventoryLedger rows in the same
// transaction as the production movement that triggered them.
// ─────────────────────────────────────────────────────────────────────────────

model ProductionOrder {
  id               String                @id @default(cuid())
  branchId         String
  branch           Branch                @relation(fields: [branchId], references: [id])
  /// Human production order number (e.g. PRO-2026-001)
  number           String                @unique
  productId        String
  product          Product               @relation("ProductionOutputProduct", fields: [productId], references: [id])
  plannedQty       Decimal               @db.Decimal(18, 4)
  producedQty      Decimal               @default(0) @db.Decimal(18, 4)
  unit             UnitOfMeasure         @default(PCS)
  status           ProductionOrderStatus @default(DRAFT)
  plannedStartDate DateTime
  plannedEndDate   DateTime
  actualStartDate  DateTime?
  actualEndDate    DateTime?
  notes            String?
  createdById      String?

  stages    ProductionStage[]
  materials ProductionMaterial[]
  outputs   ProductionOutput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([productId])
  @@index([plannedEndDate])
}

model ProductionStage {
  id          String                @id @default(cuid())
  orderId     String
  order       ProductionOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sequence    Int
  name        String
  status      ProductionStageStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  notes       String?

  @@unique([orderId, sequence])
  @@index([orderId])
}

model ProductionMaterial {
  id              String          @id @default(cuid())
  orderId         String
  order           ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  unit            UnitOfMeasure   @default(PCS)
  plannedQty      Decimal         @db.Decimal(18, 4)
  consumedQty     Decimal         @default(0) @db.Decimal(18, 4)
  fromWarehouseId String?
  fromWarehouse   Warehouse?      @relation("ProductionMaterialFromWarehouse", fields: [fromWarehouseId], references: [id])
  note            String?

  @@index([orderId])
  @@index([productId])
}

model ProductionOutput {
  id            String          @id @default(cuid())
  orderId       String
  order         ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  unit          UnitOfMeasure   @default(PCS)
  quantity      Decimal         @db.Decimal(18, 4)
  costPerUnit   Decimal         @default(0) @db.Decimal(18, 4)
  toWarehouseId String
  toWarehouse   Warehouse       @relation("ProductionOutputToWarehouse", fields: [toWarehouseId], references: [id])
  note          String?
  createdById   String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Asset Management
// ─────────────────────────────────────────────────────────────────────────────

model AssetCategory {
  id                 String             @id @default(cuid())
  name               String             @unique
  description        String?
  depreciationMethod DepreciationMethod @default(STRAIGHT_LINE)
  /// Default useful life (months) used when creating assets in this category
  defaultLifeMonths  Int                @default(60)
  /// Default salvage rate as a fraction of purchase cost (0.00-1.00)
  defaultSalvageRate Decimal            @default(0) @db.Decimal(5, 4)
  assets             Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id                      String             @id @default(cuid())
  branchId                String
  branch                  Branch             @relation(fields: [branchId], references: [id])
  categoryId              String?
  category                AssetCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /// Human asset code (e.g. AST-0001)
  code                    String             @unique
  name                    String
  description             String?
  serialNumber            String?
  location                String?
  assignedTo              String?
  condition               AssetCondition     @default(GOOD)
  status                  AssetStatus        @default(IN_USE)
  purchaseDate            DateTime
  purchaseCost            Decimal            @db.Decimal(18, 4)
  salvageValue            Decimal            @default(0) @db.Decimal(18, 4)
  usefulLifeMonths        Int                @default(60)
  depreciationMethod      DepreciationMethod @default(STRAIGHT_LINE)
  accumulatedDepreciation Decimal            @default(0) @db.Decimal(18, 4)
  lastDepreciatedAt       DateTime?
  disposedAt              DateTime?
  disposalValue           Decimal?           @db.Decimal(18, 4)
  disposalReason          String?
  notes                   String?
  createdById             String?

  movements AssetMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([categoryId])
  @@index([serialNumber])
}

model AssetMovement {
  id           String            @id @default(cuid())
  assetId      String
  asset        Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch            @relation(fields: [branchId], references: [id])
  type         AssetMovementType
  fromLocation String?
  toLocation   String?
  fromAssignee String?
  toAssignee   String?
  amount       Decimal?          @db.Decimal(18, 4)
  note         String?
  createdById  String?

  createdAt DateTime @default(now())

  @@index([assetId, createdAt])
  @@index([branchId, createdAt])
  @@index([type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Approval Workflow
// ApprovalRule: configurable (module + action + optional amount threshold) →
//   ordered list of approver roles. Rules are evaluated when a restricted
//   action is submitted, creating an ApprovalRequest with one ApprovalStep
//   per role in sequence.
// ─────────────────────────────────────────────────────────────────────────────

model ApprovalRule {
  id                 String   @id @default(cuid())
  name               String
  module             String
  action             String
  /// Minimum amount (inclusive) for this rule to apply. 0 = always applies.
  minAmount          Decimal  @default(0) @db.Decimal(18, 4)
  /// Ordered role names that must approve, highest-trust last.
  approverRoles      String[]
  escalateAfterHours Int      @default(24)
  isActive           Boolean  @default(true)
  description        String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  approvalRequests ApprovalRequest[]

  @@unique([module, action, minAmount])
  @@index([module, action, isActive])
}

model ApprovalRequest {
  id            String         @id @default(cuid())
  ruleId        String?
  rule          ApprovalRule?  @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  module        String
  action        String
  entityType    String
  entityId      String
  title         String
  summary       String?
  amount        Decimal?       @db.Decimal(18, 4)
  currency      CurrencyCode?
  branchId      String?
  requestedById String
  status        ApprovalStatus @default(PENDING)
  decidedAt     DateTime?
  note          String?

  steps ApprovalStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([module, action, status])
  @@index([entityType, entityId])
  @@index([requestedById, status])
  @@index([status, createdAt])
}

model ApprovalStep {
  id           String             @id @default(cuid())
  requestId    String
  request      ApprovalRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sequence     Int
  approverRole String
  approverId   String?
  status       ApprovalStepStatus @default(WAITING)
  decidedAt    DateTime?
  note         String?

  createdAt DateTime @default(now())

  @@unique([requestId, sequence])
  @@index([requestId, status])
  @@index([approverRole, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Document Management
// Documents are file records; DocumentLink attaches them to any entity via a
// polymorphic (entityType + entityId) pointer.
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id           String    @id @default(cuid())
  branchId     String?
  fileName     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  category     String?
  tags         String[]
  expiresAt    DateTime?
  uploadedById String
  notes        String?

  links DocumentLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, createdAt])
  @@index([category])
  @@index([expiresAt])
}

model DocumentLink {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  /// The target model name (e.g. "PurchaseOrder", "Supplier")
  entityType String
  entityId   String
  note       String?

  createdAt DateTime @default(now())

  @@unique([documentId, entityType, entityId])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM (Customer Relationship Management)
// ─────────────────────────────────────────────────────────────────────────────

model CustomerCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  /// Default discount % for this category (0–100)
  discountPct Decimal    @default(0) @db.Decimal(5, 2)
  isActive    Boolean    @default(true)

  customers Customer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id             String         @id @default(cuid())
  branchId       String
  branch         Branch         @relation(fields: [branchId], references: [id])
  /// Human customer code (e.g. CUS-001)
  code           String         @unique
  name           String
  type           CustomerType   @default(RETAIL)
  categoryId     String?
  category       CustomerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  taxId          String?
  /// Credit limit — 0 means cash-only
  creditLimit    Decimal        @default(0) @db.Decimal(18, 4)
  creditDays     Int            @default(0)
  currency       CurrencyCode   @default(BDT)
  openingBalance Decimal        @default(0) @db.Decimal(18, 4)
  loyaltyPoints  Int            @default(0)
  status         CustomerStatus @default(ACTIVE)
  notes          String?
  createdById    String?

  interactions CustomerInteraction[]
  ledger       CustomerLedger[]
  posSales     PosSale[]
  wholesaleInvoices WholesaleInvoice[]
  corporateQuotes   CorporateQuote[]
  corporateOrders   CorporateOrder[]
  corporateInvoices CorporateInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([type])
  @@index([name])
}

model CustomerInteraction {
  id          String                  @id @default(cuid())
  customerId  String
  customer    Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        CustomerInteractionType @default(NOTE)
  subject     String
  body        String?
  /// Follow-up date (when type = FOLLOW_UP or a call needs a callback)
  followUpAt  DateTime?
  completedAt DateTime?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, createdAt])
  @@index([followUpAt])
}

model CustomerLedger {
  id          String                  @id @default(cuid())
  branchId    String
  branch      Branch                  @relation(fields: [branchId], references: [id])
  customerId  String
  customer    Customer                @relation(fields: [customerId], references: [id])
  entryType   CustomerLedgerEntryType
  refType     String
  refId       String?
  description String
  debit       Decimal                 @default(0) @db.Decimal(18, 4)
  credit      Decimal                 @default(0) @db.Decimal(18, 4)
  entryDate   DateTime                @default(now())
  createdById String?

  createdAt DateTime @default(now())

  @@index([customerId, createdAt])
  @@index([branchId, createdAt])
  @@index([refType, refId])
}

// ─────────────────────────────────────────────────────────────────────────────
// POS (Point of Sale)
// Cashier opens a session (with opening float) at a warehouse-backed till.
// Each sale issues InventoryLedger OUT rows + CustomerLedger rows for credit
// inside a single $transaction. Returns reverse both.
// ─────────────────────────────────────────────────────────────────────────────

model PosSession {
  id             String           @id @default(cuid())
  branchId       String
  branch         Branch           @relation(fields: [branchId], references: [id])
  warehouseId    String
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])
  /// Cashier user id (denormalised; POS traffic rarely needs the User row)
  cashierId      String
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingFloat   Decimal          @default(0) @db.Decimal(18, 4)
  expectedCash   Decimal          @default(0) @db.Decimal(18, 4)
  countedCash    Decimal          @default(0) @db.Decimal(18, 4)
  cashVariance   Decimal          @default(0) @db.Decimal(18, 4)
  status         PosSessionStatus @default(OPEN)
  notes          String?

  sales   PosSale[]
  returns PosReturn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([cashierId, status])
  @@index([openedAt])
}

model PosSale {
  id            String        @id @default(cuid())
  /// Human sale number (e.g. POS-2026-000123)
  number        String        @unique
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id])
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  sessionId     String?
  session       PosSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cashierId     String
  saleDate      DateTime      @default(now())
  currency      CurrencyCode  @default(BDT)
  subtotal      Decimal       @default(0) @db.Decimal(18, 4)
  discountTotal Decimal       @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal       @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal       @default(0) @db.Decimal(18, 4)
  paidTotal     Decimal       @default(0) @db.Decimal(18, 4)
  changeDue     Decimal       @default(0) @db.Decimal(18, 4)
  creditAmount  Decimal       @default(0) @db.Decimal(18, 4)
  status        PosSaleStatus @default(COMPLETED)
  notes         String?

  items    PosSaleItem[]
  payments PosSalePayment[]
  returns  PosReturn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, saleDate])
  @@index([cashierId, saleDate])
  @@index([customerId, saleDate])
  @@index([sessionId])
}

model PosSaleItem {
  id           String        @id @default(cuid())
  saleId       String
  sale         PosSale       @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  description  String?
  unit         UnitOfMeasure @default(PCS)
  quantity     Decimal       @db.Decimal(18, 4)
  unitPrice    Decimal       @db.Decimal(18, 4)
  discountRate Decimal       @default(0) @db.Decimal(5, 2)
  taxRate      Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal       @db.Decimal(18, 4)
  returnedQty  Decimal       @default(0) @db.Decimal(18, 4)

  returnItems PosReturnItem[]

  @@index([saleId])
  @@index([productId])
}

model PosSalePayment {
  id        String           @id @default(cuid())
  saleId    String
  sale      PosSale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method    PosPaymentMethod
  amount    Decimal          @db.Decimal(18, 4)
  reference String?

  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([method])
}

model PosReturn {
  id            String          @id @default(cuid())
  /// Human return number (e.g. POSR-2026-000123)
  number        String          @unique
  branchId      String
  branch        Branch          @relation(fields: [branchId], references: [id])
  warehouseId   String
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id])
  saleId        String
  sale          PosSale         @relation(fields: [saleId], references: [id])
  sessionId     String?
  session       PosSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  returnDate    DateTime        @default(now())
  refundAmount  Decimal         @default(0) @db.Decimal(18, 4)
  refundMethod  PosPaymentMethod @default(CASH)
  status        PosReturnStatus @default(COMPLETED)
  reason        String?
  createdById   String?

  items PosReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, returnDate])
  @@index([saleId])
}

model PosReturnItem {
  id         String      @id @default(cuid())
  returnId   String
  return     PosReturn   @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItemId String
  saleItem   PosSaleItem @relation(fields: [saleItemId], references: [id])
  productId  String
  product    Product     @relation(fields: [productId], references: [id])
  quantity   Decimal     @db.Decimal(18, 4)
  unitPrice  Decimal     @db.Decimal(18, 4)
  lineTotal  Decimal     @db.Decimal(18, 4)

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Wholesale — customer-based bulk invoicing with credit / due tracking.
// Simpler than POS: no cash session; invoices carry a dueDate and balanceDue
// that drops as WholesalePayments arrive. Returns reverse stock + ledger.
// ─────────────────────────────────────────────────────────────────────────────

enum WholesaleInvoiceStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOIDED
  PARTIALLY_RETURNED
  RETURNED
}

enum WholesaleReturnStatus {
  COMPLETED
  VOIDED
}

model WholesaleInvoice {
  id            String                 @id @default(cuid())
  /// Human invoice number (e.g. WS-2026-000123)
  number        String                 @unique
  branchId      String
  branch        Branch                 @relation(fields: [branchId], references: [id])
  warehouseId   String
  warehouse     Warehouse              @relation(fields: [warehouseId], references: [id])
  customerId    String
  customer      Customer               @relation(fields: [customerId], references: [id])
  salesRepId    String?
  invoiceDate   DateTime               @default(now())
  dueDate       DateTime?
  currency      CurrencyCode           @default(BDT)
  subtotal      Decimal                @default(0) @db.Decimal(18, 4)
  discountTotal Decimal                @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal                @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal                @default(0) @db.Decimal(18, 4)
  paidTotal     Decimal                @default(0) @db.Decimal(18, 4)
  balanceDue    Decimal                @default(0) @db.Decimal(18, 4)
  status        WholesaleInvoiceStatus @default(CONFIRMED)
  notes         String?
  createdById   String?

  items    WholesaleInvoiceItem[]
  payments WholesalePayment[]
  returns  WholesaleReturn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, invoiceDate])
  @@index([customerId, invoiceDate])
  @@index([dueDate])
}

model WholesaleInvoiceItem {
  id           String           @id @default(cuid())
  invoiceId    String
  invoice      WholesaleInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId    String
  product      Product          @relation(fields: [productId], references: [id])
  description  String?
  unit         UnitOfMeasure    @default(PCS)
  quantity     Decimal          @db.Decimal(18, 4)
  unitPrice    Decimal          @db.Decimal(18, 4)
  discountRate Decimal          @default(0) @db.Decimal(5, 2)
  taxRate      Decimal          @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal          @db.Decimal(18, 4)
  returnedQty  Decimal          @default(0) @db.Decimal(18, 4)

  returnItems WholesaleReturnItem[]

  @@index([invoiceId])
  @@index([productId])
}

model WholesalePayment {
  id          String           @id @default(cuid())
  invoiceId   String
  invoice     WholesaleInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  method      PosPaymentMethod
  amount      Decimal          @db.Decimal(18, 4)
  reference   String?
  paidAt      DateTime         @default(now())
  createdById String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([method])
}

model WholesaleReturn {
  id           String                @id @default(cuid())
  /// Human return number (e.g. WSR-2026-000123)
  number       String                @unique
  branchId     String
  branch       Branch                @relation(fields: [branchId], references: [id])
  warehouseId  String
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id])
  invoiceId    String
  invoice      WholesaleInvoice      @relation(fields: [invoiceId], references: [id])
  returnDate   DateTime              @default(now())
  refundAmount Decimal               @default(0) @db.Decimal(18, 4)
  /// Whether refund was cash/bank or just reduced outstanding receivable
  refundToBalance Boolean            @default(true)
  refundMethod PosPaymentMethod      @default(CASH)
  status       WholesaleReturnStatus @default(COMPLETED)
  reason       String?
  createdById  String?

  items WholesaleReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, returnDate])
  @@index([invoiceId])
}

model WholesaleReturnItem {
  id            String               @id @default(cuid())
  returnId      String
  return        WholesaleReturn      @relation(fields: [returnId], references: [id], onDelete: Cascade)
  invoiceItemId String
  invoiceItem   WholesaleInvoiceItem @relation(fields: [invoiceItemId], references: [id])
  productId     String
  product       Product              @relation(fields: [productId], references: [id])
  quantity      Decimal              @db.Decimal(18, 4)
  unitPrice     Decimal              @db.Decimal(18, 4)
  lineTotal     Decimal              @db.Decimal(18, 4)

  @@index([returnId])
  @@index([invoiceItemId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Corporate Sales — B2B lifecycle: Quote → Order → Delivery → Invoice → Payment
// Stock decrements at delivery (not invoice). Customer ledger debits at invoice.
// ─────────────────────────────────────────────────────────────────────────────

enum CorporateQuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum CorporateOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_DELIVERED
  DELIVERED
  INVOICED
  CLOSED
  CANCELED
}

enum CorporateDeliveryStatus {
  DRAFT
  DISPATCHED
  DELIVERED
  VOIDED
}

enum CorporateInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOIDED
}

model CorporateQuote {
  id            String               @id @default(cuid())
  number        String               @unique
  branchId      String
  branch        Branch               @relation(fields: [branchId], references: [id])
  customerId    String
  customer      Customer             @relation(fields: [customerId], references: [id])
  salesRepId    String?
  quoteDate     DateTime             @default(now())
  validUntil    DateTime?
  currency      CurrencyCode         @default(BDT)
  subtotal      Decimal              @default(0) @db.Decimal(18, 4)
  discountTotal Decimal              @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal              @default(0) @db.Decimal(18, 4)
  status        CorporateQuoteStatus @default(DRAFT)
  notes         String?
  rejectReason  String?
  createdById   String?

  items  CorporateQuoteItem[]
  orders CorporateOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, quoteDate])
  @@index([customerId, quoteDate])
}

model CorporateQuoteItem {
  id           String         @id @default(cuid())
  quoteId      String
  quote        CorporateQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId    String
  product      Product        @relation(fields: [productId], references: [id])
  description  String?
  unit         UnitOfMeasure  @default(PCS)
  quantity     Decimal        @db.Decimal(18, 4)
  unitPrice    Decimal        @db.Decimal(18, 4)
  discountRate Decimal        @default(0) @db.Decimal(5, 2)
  taxRate      Decimal        @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal        @db.Decimal(18, 4)

  @@index([quoteId])
  @@index([productId])
}

model CorporateOrder {
  id            String               @id @default(cuid())
  number        String               @unique
  branchId      String
  branch        Branch               @relation(fields: [branchId], references: [id])
  warehouseId   String
  warehouse     Warehouse            @relation(fields: [warehouseId], references: [id])
  customerId    String
  customer      Customer             @relation(fields: [customerId], references: [id])
  quoteId       String?
  quote         CorporateQuote?      @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  salesRepId    String?
  orderDate     DateTime             @default(now())
  expectedDate  DateTime?
  paymentTerms  PaymentTerms         @default(NET_30)
  currency      CurrencyCode         @default(BDT)
  subtotal      Decimal              @default(0) @db.Decimal(18, 4)
  discountTotal Decimal              @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal              @default(0) @db.Decimal(18, 4)
  status        CorporateOrderStatus @default(DRAFT)
  notes         String?
  cancelReason  String?
  createdById   String?

  items       CorporateOrderItem[]
  deliveries  CorporateDelivery[]
  invoices    CorporateInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, orderDate])
  @@index([customerId, orderDate])
}

model CorporateOrderItem {
  id           String                  @id @default(cuid())
  orderId      String
  order        CorporateOrder          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product                 @relation(fields: [productId], references: [id])
  description  String?
  unit         UnitOfMeasure           @default(PCS)
  quantity     Decimal                 @db.Decimal(18, 4)
  unitPrice    Decimal                 @db.Decimal(18, 4)
  discountRate Decimal                 @default(0) @db.Decimal(5, 2)
  taxRate      Decimal                 @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal                 @db.Decimal(18, 4)
  deliveredQty Decimal                 @default(0) @db.Decimal(18, 4)
  invoicedQty  Decimal                 @default(0) @db.Decimal(18, 4)

  deliveryItems CorporateDeliveryItem[]
  invoiceItems  CorporateInvoiceItem[]

  @@index([orderId])
  @@index([productId])
}

model CorporateDelivery {
  id           String                  @id @default(cuid())
  number       String                  @unique
  branchId     String
  branch       Branch                  @relation(fields: [branchId], references: [id])
  warehouseId  String
  warehouse    Warehouse               @relation(fields: [warehouseId], references: [id])
  orderId      String
  order        CorporateOrder          @relation(fields: [orderId], references: [id])
  deliveryDate DateTime                @default(now())
  status       CorporateDeliveryStatus @default(DELIVERED)
  trackingNo   String?
  carrier      String?
  notes        String?
  createdById  String?

  items CorporateDeliveryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, deliveryDate])
  @@index([orderId])
}

model CorporateDeliveryItem {
  id          String             @id @default(cuid())
  deliveryId  String
  delivery    CorporateDelivery  @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  orderItemId String
  orderItem   CorporateOrderItem @relation(fields: [orderItemId], references: [id])
  productId   String
  product     Product            @relation(fields: [productId], references: [id])
  quantity    Decimal            @db.Decimal(18, 4)

  @@index([deliveryId])
  @@index([orderItemId])
  @@index([productId])
}

model CorporateInvoice {
  id            String                 @id @default(cuid())
  number        String                 @unique
  branchId      String
  branch        Branch                 @relation(fields: [branchId], references: [id])
  customerId    String
  customer      Customer               @relation(fields: [customerId], references: [id])
  orderId       String
  order         CorporateOrder         @relation(fields: [orderId], references: [id])
  invoiceDate   DateTime               @default(now())
  dueDate       DateTime?
  currency      CurrencyCode           @default(BDT)
  subtotal      Decimal                @default(0) @db.Decimal(18, 4)
  discountTotal Decimal                @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal                @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal                @default(0) @db.Decimal(18, 4)
  paidTotal     Decimal                @default(0) @db.Decimal(18, 4)
  balanceDue    Decimal                @default(0) @db.Decimal(18, 4)
  status        CorporateInvoiceStatus @default(ISSUED)
  notes         String?
  createdById   String?

  items    CorporateInvoiceItem[]
  payments CorporateInvoicePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, invoiceDate])
  @@index([customerId, invoiceDate])
  @@index([orderId])
  @@index([dueDate])
}

model CorporateInvoiceItem {
  id           String             @id @default(cuid())
  invoiceId    String
  invoice      CorporateInvoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  orderItemId  String
  orderItem    CorporateOrderItem @relation(fields: [orderItemId], references: [id])
  productId    String
  product      Product            @relation(fields: [productId], references: [id])
  description  String?
  quantity     Decimal            @db.Decimal(18, 4)
  unitPrice    Decimal            @db.Decimal(18, 4)
  discountRate Decimal            @default(0) @db.Decimal(5, 2)
  taxRate      Decimal            @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal            @db.Decimal(18, 4)

  @@index([invoiceId])
  @@index([orderItemId])
}

model CorporateInvoicePayment {
  id          String           @id @default(cuid())
  invoiceId   String
  invoice     CorporateInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  method      PosPaymentMethod
  amount      Decimal          @db.Decimal(18, 4)
  reference   String?
  paidAt      DateTime         @default(now())
  createdById String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([method])
}

// ─────────────────────────────────────────────────────────────────────────────
// Chart of Accounts (Module 14) — adjacency list + materialized path
// ─────────────────────────────────────────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountNormalSide {
  DEBIT
  CREDIT
}

model ChartAccount {
  id             String            @id @default(cuid())
  code           String            @unique
  name           String
  type           AccountType
  normalSide     AccountNormalSide
  parentId       String?
  parent         ChartAccount?     @relation("AccountTree", fields: [parentId], references: [id])
  children       ChartAccount[]    @relation("AccountTree")
  path           String
  depth          Int               @default(0)
  isPosting      Boolean           @default(true)
  isControl      Boolean           @default(false)
  currency       CurrencyCode      @default(BDT)
  branchId       String?
  branch         Branch?           @relation(fields: [branchId], references: [id])
  openingBalance Decimal           @default(0) @db.Decimal(18, 4)
  description    String?
  isActive       Boolean           @default(true)
  isSystem       Boolean           @default(false)

  journalLines    JournalEntryLine[]
  systemMappings  SystemAccountMapping[]

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([parentId])
  @@index([path])
  @@index([branchId])
  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// Accounts & Finance (Module 13) — Journal entries, system account mappings
// ─────────────────────────────────────────────────────────────────────────────

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

enum SystemAccountKey {
  CASH
  BANK_DEFAULT
  AR_CONTROL
  AP_CONTROL
  INVENTORY
  COGS
  SALES_REVENUE
  SALES_RETURNS
  DISCOUNT_GIVEN
  TAX_PAYABLE
  TAX_RECOVERABLE
  PURCHASE_EXPENSE
  FX_GAIN
  FX_LOSS
  RETAINED_EARNINGS
  OPENING_BALANCE_EQUITY
  ROUNDING
}

model SystemAccountMapping {
  id        String           @id @default(cuid())
  key       SystemAccountKey
  branchId  String?
  accountId String
  account   ChartAccount     @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, branchId])
  @@index([accountId])
}

model JournalEntry {
  id             String        @id @default(cuid())
  number         String        @unique
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  periodId       String
  period         Period        @relation(fields: [periodId], references: [id])
  date           DateTime
  memo           String?
  reference      String?
  status         JournalStatus @default(DRAFT)
  sourceModule   String?
  sourceRefType  String?
  sourceRefId    String?
  reversesId     String?       @unique
  reverses       JournalEntry? @relation("JournalReversal", fields: [reversesId], references: [id])
  reversedBy     JournalEntry? @relation("JournalReversal")

  totalDebit  Decimal @default(0) @db.Decimal(18, 4)
  totalCredit Decimal @default(0) @db.Decimal(18, 4)

  lines       JournalEntryLine[]

  createdById String?
  postedById  String?
  postedAt    DateTime?
  voidedById  String?
  voidedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([sourceModule, sourceRefType, sourceRefId])
  @@index([branchId, date])
  @@index([status])
  @@index([periodId])
}

model JournalEntryLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lineNo    Int
  accountId String
  account   ChartAccount @relation(fields: [accountId], references: [id])
  debit     Decimal      @default(0) @db.Decimal(18, 4)
  credit    Decimal      @default(0) @db.Decimal(18, 4)
  currency  CurrencyCode @default(BDT)
  fxRate    Decimal      @default(1) @db.Decimal(18, 6)
  costCenter String?
  memo      String?

  @@index([entryId])
  @@index([accountId])
}
