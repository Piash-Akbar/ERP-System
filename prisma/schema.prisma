// Annex Leather ERP — Prisma schema
// Phase 0 foundation tables only. Module-specific models (inventory,
// sales, accounts, etc.) are added as their modules are built.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum CurrencyCode {
  BDT
  INR
  USD
  EUR
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProductType {
  RAW_MATERIAL
  WORK_IN_PROGRESS
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
}

enum UnitOfMeasure {
  PCS
  KG
  G
  M
  M2
  L
  ML
  BOX
  PACK
  PAIR
  SET
}

enum WarehouseType {
  MAIN
  STORE
  WIP
  QUARANTINE
  DAMAGED
  SHOWROOM
}

enum InventoryDirection {
  IN
  OUT
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum PaymentTerms {
  COD
  NET_15
  NET_30
  NET_45
  NET_60
  NET_90
}

enum PurchaseRequisitionStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  CLOSED
}

enum PurchasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum GoodsReceivingStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PurchaseInvoiceStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PurchaseInvoiceMatch {
  UNMATCHED
  MATCHED
  DISPUTED
}

enum SupplierPaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  WIRE_TRANSFER
  MOBILE_BANKING
  OTHER
}

enum SupplierLedgerEntryType {
  PURCHASE
  PAYMENT
  ADJUSTMENT
  OPENING
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & RBAC
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  name            String
  phone           String?
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)
  defaultBranchId String?
  defaultBranch   Branch?    @relation("UserDefaultBranch", fields: [defaultBranchId], references: [id])

  roles         UserRole[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  notifications Notification[] @relation("NotificationRecipient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id     String @id @default(cuid())
  /// "<module>:<action>" — see src/lib/permissions.ts
  key    String @unique
  module String
  action String

  roles RolePermission[]

  @@index([module])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Multi-branch
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id                 String       @id @default(cuid())
  code               String       @unique
  name               String
  type               String       @default("MAIN") // MAIN / FACTORY / SHOWROOM / WAREHOUSE
  currency           CurrencyCode @default(BDT)
  address            String?
  phone              String?
  email              String?
  allowNegativeStock Boolean      @default(false)
  isActive           Boolean      @default(true)

  defaultForUsers  User[]                @relation("UserDefaultBranch")
  periods          Period[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  warehouses       Warehouse[]
  ledger           InventoryLedger[]
  suppliers        Supplier[]
  requisitions     PurchaseRequisition[]
  purchaseOrders   PurchaseOrder[]
  grns             GoodsReceiving[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]
  supplierLedger   SupplierLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

// ─────────────────────────────────────────────────────────────────────────────
// Fiscal period lock (used by accounts + inventory stock freeze)
// ─────────────────────────────────────────────────────────────────────────────

model Period {
  id       String       @id @default(cuid())
  branchId String
  branch   Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name     String // e.g. "FY2025-26 Apr"
  startsAt DateTime
  endsAt   DateTime
  status   PeriodStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, name])
  @@index([branchId, status])
  @@index([startsAt, endsAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit log (append-only; no update/delete in app code)
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(cuid())
  actorId    String?
  actor      User?   @relation("AuditActor", fields: [actorId], references: [id])
  branchId   String?
  branch     Branch? @relation(fields: [branchId], references: [id])
  module     String
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([module, createdAt])
  @@index([entityType, entityId])
  @@index([branchId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications (SSE-delivered in Phase 1)
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id          String               @id @default(cuid())
  recipientId String
  recipient   User                 @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?              @relation(fields: [branchId], references: [id])
  severity    NotificationSeverity @default(INFO)
  module      String
  title       String
  body        String?
  href        String?
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([module])
}

// ─────────────────────────────────────────────────────────────────────────────
// Product master
// ─────────────────────────────────────────────────────────────────────────────

model ProductCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    ProductCategory[] @relation("CategoryTree")
  products    Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model ProductBrand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String                    @id @default(cuid())
  sku                String                    @unique
  barcode            String?                   @unique
  name               String
  description        String?
  type               ProductType               @default(FINISHED_GOOD)
  unit               UnitOfMeasure             @default(PCS)
  categoryId         String?
  category           ProductCategory?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brandId            String?
  brand              ProductBrand?             @relation(fields: [brandId], references: [id], onDelete: SetNull)
  costPrice          Decimal                   @default(0) @db.Decimal(18, 4)
  sellPrice          Decimal                   @default(0) @db.Decimal(18, 4)
  taxRate            Decimal                   @default(0) @db.Decimal(5, 2)
  reorderLevel       Decimal                   @default(0) @db.Decimal(18, 4)
  reorderQty         Decimal                   @default(0) @db.Decimal(18, 4)
  isActive           Boolean                   @default(true)
  imageUrl           String?
  ledger             InventoryLedger[]
  requisitionItems   PurchaseRequisitionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  grnItems           GoodsReceivingItem[]
  invoiceItems       PurchaseInvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([isActive])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────────────
// Warehouse + stock ledger (single source of truth for inventory)
// ─────────────────────────────────────────────────────────────────────────────

model Warehouse {
  id       String            @id @default(cuid())
  branchId String
  branch   Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  code     String
  name     String
  type     WarehouseType     @default(MAIN)
  address  String?
  isActive Boolean           @default(true)
  ledger   InventoryLedger[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  goodsReceivings GoodsReceiving[]

  @@unique([branchId, code])
  @@index([branchId, isActive])
}

model InventoryLedger {
  id          String             @id @default(cuid())
  branchId    String
  branch      Branch             @relation(fields: [branchId], references: [id])
  warehouseId String
  warehouse   Warehouse          @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product            @relation(fields: [productId], references: [id])
  direction   InventoryDirection
  quantity    Decimal            @db.Decimal(18, 4)
  costPerUnit Decimal            @default(0) @db.Decimal(18, 4)
  refType     String
  refId       String?
  note        String?
  createdById String?

  createdAt DateTime @default(now())

  @@index([productId, createdAt])
  @@index([branchId, warehouseId, productId])
  @@index([refType, refId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Suppliers
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id             String         @id @default(cuid())
  branchId       String
  branch         Branch         @relation(fields: [branchId], references: [id])
  /// Human supplier code (e.g. SUP-001)
  code           String         @unique
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  taxId          String?
  paymentTerms   PaymentTerms   @default(NET_30)
  currency       CurrencyCode   @default(BDT)
  openingBalance Decimal        @default(0) @db.Decimal(18, 4)
  status         SupplierStatus @default(ACTIVE)
  notes          String?
  createdById    String?

  purchaseOrders   PurchaseOrder[]
  grns             GoodsReceiving[]
  purchaseInvoices PurchaseInvoice[]
  payments         SupplierPayment[]
  ledger           SupplierLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status])
  @@index([name])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Requisition (PR)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseRequisition {
  id             String                    @id @default(cuid())
  branchId       String
  branch         Branch                    @relation(fields: [branchId], references: [id])
  /// Human PR number (e.g. PR-2026-001)
  number         String                    @unique
  department     String
  requestedBy    String
  priority       PurchasePriority          @default(MEDIUM)
  status         PurchaseRequisitionStatus @default(DRAFT)
  requiredDate   DateTime
  notes          String?
  createdById    String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?

  items          PurchaseRequisitionItem[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([createdAt])
}

model PurchaseRequisitionItem {
  id             String              @id @default(cuid())
  requisitionId  String
  requisition    PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Free-text name when no SKU exists yet
  productName    String
  unit           UnitOfMeasure       @default(PCS)
  quantity       Decimal             @db.Decimal(18, 4)
  estimatedPrice Decimal             @default(0) @db.Decimal(18, 4)
  note           String?

  @@index([requisitionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Order (PO)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String               @id @default(cuid())
  branchId      String
  branch        Branch               @relation(fields: [branchId], references: [id])
  /// Human PO number (e.g. PO-2026-001)
  number        String               @unique
  supplierId    String
  supplier      Supplier             @relation(fields: [supplierId], references: [id])
  requisitionId String?
  requisition   PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  status        PurchaseOrderStatus  @default(DRAFT)
  orderDate     DateTime             @default(now())
  deliveryDate  DateTime
  currency      CurrencyCode         @default(BDT)
  subtotal      Decimal              @default(0) @db.Decimal(18, 4)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 4)
  discountTotal Decimal              @default(0) @db.Decimal(18, 4)
  grandTotal    Decimal              @default(0) @db.Decimal(18, 4)
  notes         String?
  createdById   String?
  approvedById  String?
  approvedAt    DateTime?
  cancelledAt   DateTime?

  items    PurchaseOrderItem[]
  grns     GoodsReceiving[]
  invoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([supplierId])
  @@index([requisitionId])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  description     String?
  unit            UnitOfMeasure @default(PCS)
  orderedQty      Decimal       @db.Decimal(18, 4)
  receivedQty     Decimal       @default(0) @db.Decimal(18, 4)
  unitPrice       Decimal       @db.Decimal(18, 4)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  discountRate    Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal       @default(0) @db.Decimal(18, 4)

  grnItems GoodsReceivingItem[]

  @@index([purchaseOrderId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Goods Receiving Note (GRN)
// ─────────────────────────────────────────────────────────────────────────────

model GoodsReceiving {
  id              String               @id @default(cuid())
  branchId        String
  branch          Branch               @relation(fields: [branchId], references: [id])
  number          String               @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  warehouseId     String
  warehouse       Warehouse            @relation(fields: [warehouseId], references: [id])
  status          GoodsReceivingStatus @default(DRAFT)
  receivedDate    DateTime             @default(now())
  receivedById    String
  notes           String?
  invoiceId       String?

  items    GoodsReceivingItem[]
  invoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([purchaseOrderId])
  @@index([supplierId])
}

model GoodsReceivingItem {
  id                  String            @id @default(cuid())
  grnId               String
  grn                 GoodsReceiving    @relation(fields: [grnId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  productId           String
  product             Product           @relation(fields: [productId], references: [id])
  receivedQty         Decimal           @db.Decimal(18, 4)
  rejectedQty         Decimal           @default(0) @db.Decimal(18, 4)
  unitCost            Decimal           @db.Decimal(18, 4)
  note                String?

  @@index([grnId])
  @@index([purchaseOrderItemId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Purchase Invoice (supplier bill, 3-way match with PO + GRN)
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseInvoice {
  id              String                @id @default(cuid())
  branchId        String
  branch          Branch                @relation(fields: [branchId], references: [id])
  number          String                @unique
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  grnId           String?
  grn             GoodsReceiving?       @relation(fields: [grnId], references: [id], onDelete: SetNull)
  status          PurchaseInvoiceStatus @default(PENDING)
  matching        PurchaseInvoiceMatch  @default(UNMATCHED)
  invoiceDate     DateTime              @default(now())
  dueDate         DateTime
  currency        CurrencyCode          @default(BDT)
  subtotal        Decimal               @default(0) @db.Decimal(18, 4)
  taxTotal        Decimal               @default(0) @db.Decimal(18, 4)
  discountTotal   Decimal               @default(0) @db.Decimal(18, 4)
  grandTotal      Decimal               @default(0) @db.Decimal(18, 4)
  paidAmount      Decimal               @default(0) @db.Decimal(18, 4)
  notes           String?
  createdById     String?

  items    PurchaseInvoiceItem[]
  payments SupplierPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, status, createdAt])
  @@index([supplierId])
  @@index([dueDate])
}

model PurchaseInvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  description String?
  unit        UnitOfMeasure   @default(PCS)
  quantity    Decimal         @db.Decimal(18, 4)
  unitPrice   Decimal         @db.Decimal(18, 4)
  taxRate     Decimal         @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal         @db.Decimal(18, 4)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Supplier Payment
// ─────────────────────────────────────────────────────────────────────────────

model SupplierPayment {
  id          String                @id @default(cuid())
  branchId    String
  branch      Branch                @relation(fields: [branchId], references: [id])
  number      String                @unique
  supplierId  String
  supplier    Supplier              @relation(fields: [supplierId], references: [id])
  invoiceId   String?
  invoice     PurchaseInvoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  method      SupplierPaymentMethod @default(BANK_TRANSFER)
  paymentDate DateTime              @default(now())
  amount      Decimal               @db.Decimal(18, 4)
  currency    CurrencyCode          @default(BDT)
  reference   String?
  notes       String?
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId, createdAt])
  @@index([supplierId, createdAt])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Supplier Ledger (append-only; runs debit/credit per supplier)
// Debit = purchase (increases payable). Credit = payment (reduces payable).
// ─────────────────────────────────────────────────────────────────────────────

model SupplierLedger {
  id          String                  @id @default(cuid())
  branchId    String
  branch      Branch                  @relation(fields: [branchId], references: [id])
  supplierId  String
  supplier    Supplier                @relation(fields: [supplierId], references: [id])
  entryType   SupplierLedgerEntryType
  refType     String
  refId       String?
  description String
  debit       Decimal                 @default(0) @db.Decimal(18, 4)
  credit      Decimal                 @default(0) @db.Decimal(18, 4)
  entryDate   DateTime                @default(now())
  createdById String?

  createdAt DateTime @default(now())

  @@index([supplierId, createdAt])
  @@index([branchId, createdAt])
  @@index([refType, refId])
}
